# ─────────────────────────────────────────────────────────────
# Makoquiz 環境變數範例
#
#   1. 複製一份成 .env
#        Windows (PowerShell):  Copy-Item .env.example .env
#        macOS / Linux:         cp .env.example .env
#   2. 依需要修改下面的值（沒有要用的可以整行刪掉或留著註解）
#   3. .env 已被 .gitignore 忽略，不會上傳到 GitHub —— 密鑰放心填
#
# 全部都是「選用」的：連 .env 都沒有，程式一樣跑得起來
# （用預設密碼 + 本機題庫市集）。
# ─────────────────────────────────────────────────────────────

# ── 管理後台密碼 ──
# 後台 /admin 的登入密碼。正式使用強烈建議改掉預設值。
NUXT_HOST_PASSWORD=admin123

# ── 服務埠號 ──
# 用 啟動.bat / start.ps1 時請改用 -Port 參數（它會覆蓋這裡）。
PORT=3000

# ── 對外網址（選用）──
# 參與者掃 QR / 加入用的公開網址。留空時：
#   * 用 啟動.bat  → 會自動帶入 cloudflared 臨時通道網址
#   * 直接 npm start → 會把 localhost 自動換成區網 IP（同一個 wifi 才連得到）
# 只有你有固定網域 / 反向代理時才需要手動填。
# NUXT_PUBLIC_URL=https://quiz.example.com

# ── 資料目錄（選用）──
# 簡報 JSON、上傳的圖片與音檔、按鈕音效存放位置，預設是專案底下的 ./data。
# MAKOQUIZ_DATA_DIR=D:\makoquiz-data

# ─────────────────────────────────────────────────────────────
# 題庫市集雲端（選用，Supabase）
#
# 不填 = 本機市集（存在 data/gallery/，只有自己上架的東西，程式一切正常）。
# 要跟別人共用題庫才需要：先把 docs/supabase-setup.sql 貼進 Supabase 的
# SQL Editor 跑一次。細節見 README 的「接上 Supabase」。
# ─────────────────────────────────────────────────────────────

# SUPABASE_URL=https://xxxxxxxx.supabase.co

# publishable key（舊名 anon key，兩個名字都收）—— 公開的，安全性靠資料庫 RLS。
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# secret key（舊名 service_role key）—— 只放在「市集管理員」那一台機器！
# 有它才有市集後台（列出被隱藏的、刪別人的、上下架）。一般使用者不要填。
# SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx
